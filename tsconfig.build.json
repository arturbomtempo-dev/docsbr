{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationMap": false,
        "sourceMap": false,
        "removeComments": false
    },
    "include": ["src/**/*.ts"],
    "exclude": ["tests", "src/test.ts"]
}
